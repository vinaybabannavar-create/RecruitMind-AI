# RecruitMind AI — Environment Variables
# Copy this file to .env and fill in your values
# Run: cp .env.example .env

# ── LLM API (Groq — free at console.groq.com) ────────────────────────────────
# Get your free key at: https://console.groq.com
# If not set, the system runs in rule-based offline mode (still fully functional)
GROQ_API_KEY=your_groq_api_key_here

# ── API URL (used by Streamlit UI) ───────────────────────────────────────────
API_URL=http://localhost:8000
